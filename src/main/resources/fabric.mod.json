{
  "schemaVersion": 1,
  "id": "simple",
  "version": "${version}",

  "name": "simple",
  "description": "An overhaul mod to make minecraft what I want it to be.",
  "authors": [],
  "contact": {},

  "license": "All-Rights-Reserved",
  "icon": "assets/simple/icon.png",

  "environment": "*",
  "entrypoints": {
    "fabric-datagen": ["app.masterwork.simple.client.SimpleDataGenerator"],
    "client": ["app.masterwork.simple.client.SimpleClient"],
    "main": ["app.masterwork.simple.Simple"]
  },

  "mixins": [
    "simple.mixins.json"
    ,{
      "config": "simple.client.mixins.json",
      "environment": "client"
    }
  ],

  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  }
}
